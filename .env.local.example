# Sanity CMS Configuration
# Create a project at https://www.sanity.io/
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API Token (for server-side reads and writes)
SANITY_API_READ_TOKEN=your_read_token_here
SANITY_API_WRITE_TOKEN=your_write_token_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://maryminzalucas.com

# Contact form (optional: use Sanity or your own API)
CONTACT_EMAIL=mary@maryminzalucas.com

# WhatsApp number (include country code, no + sign)
NEXT_PUBLIC_WHATSAPP=255XXXXXXXXX
